# ── Postgres ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vigil
DB_USER=postgres
DB_PASSWORD=postgres

# ── LLM (Groq — OpenAI-compatible) ───────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Agent settings ────────────────────────────────────────
AGENT_MAX_ITERATIONS=10
# Services that can be auto-actioned (comma-separated, local-host is never allowed)
ACTION_ALLOWLIST=checkout-api

# ── JWT Auth ──────────────────────────────────────────────
JWT_SECRET=supersecretjwtsigningkey_changeme
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
DEMO_USERNAME=admin
DEMO_PASSWORD=vigil2025

# ── SMTP / Email Notifications ────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
ALERT_EMAIL_TO=your_alert_recipient@example.com

# ── Metrics Loop ──────────────────────────────────────────
METRICS_INTERVAL_SECONDS=5
ANOMALY_MIN_INTERVAL=30
ANOMALY_MAX_INTERVAL=60
